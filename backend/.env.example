# Server Configuration
PORT=3000

# Google Maps Platform Configuration
# 1. Go to https://console.cloud.google.com/
# 2. Enable "Places API" for your project
# 3. Generate an API Key under Credentials
# 4. Paste the API Key below and rename this file to '.env'
GOOGLE_PLACES_API_KEY=YOUR_SECURE_GOOGLE_PLACES_API_KEY_HERE

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY_HERE
